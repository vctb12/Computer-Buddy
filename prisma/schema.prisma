generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  USER
  PLATFORM_OWNER
}

enum OrgRole {
  STORE_ADMIN
  SALES
  BUILDER
  SUPPORT
  FINANCE
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  EXPIRED
  CONVERTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  READY_FOR_DISPATCH
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum WorkOrderStatus {
  QUEUED
  ASSIGNED
  IN_PROGRESS
  QA
  DONE
  BLOCKED
}

enum QuoteLineType {
  PART
  SERVICE
  SHIPPING
  DISCOUNT
  ADJUSTMENT
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  image         String?
  emailVerified DateTime?

  // Credentials login support
  passwordHash  String?

  platformRole  PlatformRole  @default(USER)

  accounts      Account[]
  sessions      Session[]

  memberships   OrgMembership[]
  createdQuotes Quote[]      @relation("QuoteCreatedBy")
  assignedWorkOrders WorkOrder[] @relation("WorkOrderAssignedTo")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String

  // Billing (Stripe Billing at org level)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  settings   OrgSettings?
  branches   Branch[]
  members    OrgMembership[]
  customers  Customer[]
  products   Product[]

  quotes     Quote[]
  orders     Order[]
  workOrders WorkOrder[]
  inventoryStock InventoryStock[]
  serialNumbers SerialNumber[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model OrgSettings {
  id        String   @id @default(cuid())
  orgId     String   @unique
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // UAE defaults
  vatRate               Decimal  @db.Decimal(5, 4) @default(0.0500)
  vatWaiverThresholdAed Decimal? @db.Decimal(10, 2)

  currency              String   @default("AED")
  allowCOD              Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("org_settings")
}

model Branch {
  id        String @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name      String
  emirate   String?
  address   String?
  phone     String?

  members   OrgMembership[]
  stock     InventoryStock[]
  quotes    Quote[]
  orders    Order[]
  workOrders WorkOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
  @@map("branches")
}

model OrgMembership {
  id        String  @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole
  branchId  String?

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([orgId, userId])
  @@map("org_memberships")
}

model Product {
  id        String @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  sku       String
  slug      String
  name      String
  brand     String?
  category  String
  priceAed  Decimal @db.Decimal(10, 2)

  specs     Json?
  isActive  Boolean @default(true)

  stock     InventoryStock[]
  quoteLines QuoteLine[]
  serialNumbers SerialNumber[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, sku])
  @@unique([orgId, slug])
  @@map("products")
}

model InventoryStock {
  id           String @id @default(cuid())
  orgId        String
  branchId     String
  productId    String

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  onHand       Int @default(0)
  reserved     Int @default(0)
  reorderPoint Int @default(0)

  updatedAt DateTime @updatedAt

  @@unique([branchId, productId])
  @@map("inventory_stock")
}

model Customer {
  id        String @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  email     String?
  phone     String?
  name      String
  address   Json?

  quotes    Quote[]
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model Quote {
  id        String @id @default(cuid())
  orgId     String
  branchId  String
  createdByUserId String
  customerId String

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User         @relation("QuoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  customer  Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)

  status    QuoteStatus @default(DRAFT)

  shareToken String @unique
  expiresAt  DateTime?

  subtotalAed Decimal @db.Decimal(10, 2) @default(0)
  discountAed Decimal @db.Decimal(10, 2) @default(0)
  vatAed      Decimal @db.Decimal(10, 2) @default(0)
  totalAed    Decimal @db.Decimal(10, 2) @default(0)

  lines     QuoteLine[]
  order     Order?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quotes")
}

model QuoteLine {
  id        String @id @default(cuid())
  quoteId   String
  type      QuoteLineType
  productId String?

  title     String
  quantity  Int @default(1)
  unitPriceAed Decimal @db.Decimal(10, 2) @default(0)
  lineTotalAed Decimal @db.Decimal(10, 2) @default(0)

  quote     Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("quote_lines")
}

model Order {
  id        String @id @default(cuid())
  orgId     String
  branchId  String
  customerId String
  quoteId   String? @unique

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer  Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quote     Quote?       @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)

  subtotalAed Decimal @db.Decimal(10, 2) @default(0)
  discountAed Decimal @db.Decimal(10, 2) @default(0)
  vatAed      Decimal @db.Decimal(10, 2) @default(0)
  totalAed    Decimal @db.Decimal(10, 2) @default(0)

  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?

  workOrder WorkOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orders")
}

model WorkOrder {
  id        String @id @default(cuid())
  orgId     String
  branchId  String
  orderId   String @unique
  assignedToUserId String?

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  assignedTo User?       @relation("WorkOrderAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  status    WorkOrderStatus @default(QUEUED)

  steps     WorkOrderStep[]
  serials   SerialNumber[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("work_orders")
}

model WorkOrderStep {
  id          String @id @default(cuid())
  workOrderId String
  title       String
  sequence    Int
  isDone      Boolean @default(false)
  doneAt      DateTime?
  notes       String?

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, sequence])
  @@map("work_order_steps")
}

model SerialNumber {
  id          String @id @default(cuid())
  orgId       String
  workOrderId String
  productId   String
  serial      String

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workOrder WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@unique([orgId, serial])
  @@map("serial_numbers")
}

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String?
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?

  createdAt   DateTime @default(now())

  @@map("audit_logs")
}
